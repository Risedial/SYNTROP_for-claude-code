# First Aid Study PWA — Environment Variables Template
# Copy this file to .env.local for local development
# For production: inject via Vercel CLI (see DEPLOYMENT-GUIDE.md)

# ─────────────────────────────────────────────────────────────
# Upstash Redis (Required for cloud sync feature)
# ─────────────────────────────────────────────────────────────

# REST API endpoint for your Upstash Redis database
# Format: https://your-db-name.upstash.io
# Get from: console.upstash.com → your database → REST API → Endpoint
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io

# REST API token (read+write access)
# Get from: console.upstash.com → your database → REST API → Token
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────
# - These variables are ONLY used by the /api/sync serverless function
# - They are NEVER exposed to the browser/client bundle
# - Without these, the app works fully (study, skills, progress, offline)
#   but cloud sync (save/restore) will not function
# - Upstash free tier: 10,000 commands/day, 256MB storage — sufficient for single user
